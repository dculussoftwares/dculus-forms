{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express.js + GraphQL backend for Dculus Forms",
  "type": "module",
  "main": "dist/apps/backend/src/index.js",
  "imports": {
    "#graphql-errors": "./dist/apps/backend/src/lib/graphqlErrors.js",
    "#prisma-client": "./dist/apps/backend/src/generated/prisma/client.js"
  },
  "scripts": {
    "predev": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/apps/backend/src/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "tsx src/scripts/migrate-deploy.ts",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:dedupe-templates": "tsx src/scripts/dedupe-templates.ts",
    "db:migrate-layout": "tsx src/scripts/migrate-form-layout.ts",
    "db:migrate-bg-images": "tsx src/scripts/migrate-background-images.ts",
    "auth:generate": "pnpm dlx @better-auth/cli generate",
    "admin:setup": "tsx src/scripts/setup-admin.ts",
    "dev:coverage": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest watch --coverage"
  },
  "dependencies": {
    "@ai-sdk/azure": "3.0.66",
    "@ai-sdk/openai": "3.0.65",
    "@apollo/server": "^5.5.0",
    "@as-integrations/express4": "^1.1.2",
    "@aws-sdk/client-s3": "3.1085.0",
    "@aws-sdk/s3-request-presigner": "3.1085.0",
    "@dculus/types": "workspace:*",
    "@dculus/utils": "workspace:*",
    "@graphql-tools/schema": "10.0.36",
    "@hocuspocus/extension-database": "^4.3.0",
    "@hocuspocus/server": "^4.3.0",
    "@maxmind/geoip2-node": "6.1.0",
    "@pdfme/common": "6.1.11",
    "@pdfme/generator": "6.1.11",
    "@pdfme/schemas": "6.1.11",
    "@prisma/adapter-pg": "6.19.2",
    "@prisma/client": "6.19.2",
    "@sentry/node": "^10.65.0",
    "@sentry/profiling-node": "^10.65.0",
    "@types/bcryptjs": "3.0.0",
    "@types/graphql-upload": "17.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.2.0",
    "@types/ws": "8.18.1",
    "ai": "6.0.191",
    "bcryptjs": "3.0.3",
    "better-auth": "^1.6.23",
    "chargebee": "3.28.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "countries-and-timezones": "3.9.0",
    "dotenv": "17.4.2",
    "exceljs": "4.4.0",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "graphql": "^16.14.1",
    "graphql-depth-limit": "^1.1.0",
    "graphql-tag": "2.12.7",
    "graphql-type-json": "0.3.2",
    "graphql-upload": "17.0.0",
    "graphql-ws": "6.1.0",
    "helmet": "^7.2.0",
    "i18n-iso-countries": "7.14.0",
    "iso-3166-1-alpha-2": "1.0.2",
    "jsonwebtoken": "9.0.3",
    "lib0": "0.2.117",
    "libphonenumber-js": "^1.13.8",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nanoid": "5.1.5",
    "nodemailer": "^8.0.5",
    "pg": "^8.13.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prisma": "6.19.2",
    "ws": "^8.21.0",
    "yjs": "13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@faker-js/faker": "10.5.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/graphql-depth-limit": "1.1.6",
    "@types/morgan": "^1.9.10",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.11.10",
    "@types/supertest": "6.0.3",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "8.57.1",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vitest-mock-extended": "3.1.0"
  }
}