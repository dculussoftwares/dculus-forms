{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "**/*.ts",
    "../../apps/backend/src/**/*.ts"
  ],
  "exclude": [
    "reports"
  ]
}