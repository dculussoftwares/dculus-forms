{
  "name": "@dculus/types",
  "version": "1.0.0",
  "description": "Shared types for Dculus Forms",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./graphql.js": {
      "types": "./dist/graphql.d.ts",
      "import": "./dist/graphql.js"
    },
    "./ai.js": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "libphonenumber-js": "^1.13.9",
    "react-hook-form": "7.82.0",
    "zod": "^4.4.3"
  }
}
