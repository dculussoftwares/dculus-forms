{
  "name": "dculus-forms",
  "version": "1.0.0",
  "description": "A monorepo for Dculus Forms with Express.js + GraphQL backend and React + Material UI frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter backend --filter form-app --filter form-viewer --filter admin-app --filter ui run dev",
    "prod": "./scripts/local-prod.sh",
    "build": "pnpm run --recursive build",
    "clean": "pnpm run --recursive clean",
    "lint": "pnpm run --recursive lint",
    "test": "pnpm run --recursive test",
    "test:unit": "pnpm --filter backend test",
    "test:unit:watch": "pnpm --filter backend test:watch",
    "test:unit:ui": "pnpm --filter backend test:ui",
    "test:unit:coverage": "pnpm --filter backend test:coverage",
    "type-check": "pnpm run --recursive type-check",
    "backend:dev": "pnpm --filter backend dev",
    "backend:build": "pnpm --filter backend build",
    "backend:start": "pnpm --filter backend start",
    "form-app:dev": "pnpm --filter form-app dev",
    "form-app:build": "pnpm --filter form-app build",
    "form-app:preview": "pnpm --filter form-app preview",
    "form-viewer:dev": "pnpm --filter form-viewer dev",
    "form-viewer:build": "pnpm --filter form-viewer build",
    "form-viewer:preview": "pnpm --filter form-viewer preview",
    "admin-app:dev": "pnpm --filter admin-app dev",
    "admin-app:build": "pnpm --filter admin-app build",
    "admin-app:preview": "pnpm --filter admin-app preview",
    "db:generate": "pnpm --filter backend db:generate",
    "db:push": "pnpm --filter backend db:push",
    "db:migrate:dev": "pnpm --filter backend db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter backend db:migrate:deploy",
    "db:studio": "pnpm --filter backend db:studio",
    "db:seed": "pnpm --filter backend db:seed",
    "db:migrate-layout": "pnpm --filter backend db:migrate-layout",
    "db:migrate-bg-images": "pnpm --filter backend db:migrate-bg-images",
    "db:setup": "./scripts/setup-db.sh",
    "admin:setup": "pnpm --filter backend admin:setup",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "ui:storybook": "pnpm --filter @dculus/ui storybook",
    "ui:build-storybook": "pnpm --filter @dculus/ui build-storybook",
    "test:integration": "TS_NODE_PROJECT=test/integration/tsconfig.json cucumber-js 'test/integration/features/*.feature' --config test/integration/cucumber.js",
    "test:integration:by-tags": "./test-integration-by-tags.sh",
    "test:integration:dry-run": "./test-integration-by-tags.sh --dry-run",
    "test:integration:production": "cross-env TEST_BASE_URL=https://dculus-forms-backend.reddune-e5ba9473.eastus.azurecontainerapps.io TS_NODE_PROJECT=test/integration/tsconfig.json cucumber-js 'test/integration/features/*.feature' --config test/integration/cucumber.production.js",
    "test:integration:health": "TS_NODE_PROJECT=test/integration/tsconfig.json cucumber-js 'test/integration/features/health.feature' --require-module ts-node/register --require test/integration/support/world.ts --require test/integration/support/hooks.ts --require test/integration/step-definitions/common.steps.ts --require 'test/integration/step-definitions/*.steps.ts'",
    "test:integration:auth": "TS_NODE_PROJECT=test/integration/tsconfig.json cucumber-js 'test/integration/features/auth*.feature' --require-module ts-node/register --require test/integration/support/world.ts --require test/integration/support/hooks.ts --require test/integration/step-definitions/common.steps.ts --require 'test/integration/step-definitions/*.steps.ts'",
    "test:integration:auth:production": "cross-env TEST_BASE_URL=https://dculus-forms-backend.reddune-e5ba9473.eastus.azurecontainerapps.io TS_NODE_PROJECT=test/integration/tsconfig.json cucumber-js 'test/integration/features/auth*.feature' --require-module ts-node/register --require test/integration/support/world.ts --require test/integration/support/hooks.ts --require test/integration/step-definitions/common.steps.ts --require 'test/integration/step-definitions/*.steps.ts'",
    "test:integration:health:production": "cross-env TEST_BASE_URL=https://dculus-forms-backend.reddune-e5ba9473.eastus.azurecontainerapps.io TS_NODE_PROJECT=test/integration/tsconfig.json cucumber-js 'test/integration/features/health.feature' --require-module ts-node/register --require test/integration/support/world.ts --require test/integration/support/hooks.ts --require test/integration/step-definitions/common.steps.ts --require 'test/integration/step-definitions/*.steps.ts'",
    "test:integration:coverage": "rm -rf coverage/* && NODE_V8_COVERAGE=coverage/tmp TS_NODE_PROJECT=test/integration/tsconfig.json cucumber-js 'test/integration/features/*.feature' --config test/integration/cucumber.coverage.js && c8 report --config .c8rc.json",
    "test:integration:coverage:health": "rm -rf coverage/* && NODE_V8_COVERAGE=coverage/tmp TS_NODE_PROJECT=test/integration/tsconfig.json cucumber-js 'test/integration/features/health.feature' --config test/integration/cucumber.coverage.js && c8 report --config .c8rc.json",
    "test:e2e": "E2E_EMAIL=${E2E_EMAIL:-cloude2etest@mailinator.com} E2E_PASSWORD=${E2E_PASSWORD:-cloude2etest@mailinator.com} E2E_FORM_APP_URL=${E2E_FORM_APP_URL:-http://localhost:3000} E2E_HEADLESS=${E2E_HEADLESS:-true} E2E_FORM_VIEWER_URL=${E2E_FORM_VIEWER_URL:-http://localhost:5173} E2E_BACKEND_URL=${E2E_BACKEND_URL:-http://localhost:4000} TS_NODE_PROJECT=test/e2e/tsconfig.json cucumber-js --config test/e2e/cucumber.js --tags 'not @mass-responses and not @persistence and not @skip-ci'",
    "test:e2e:mass-responses": "E2E_FORM_APP_URL=${E2E_FORM_APP_URL:-http://localhost:3000} E2E_HEADLESS=${E2E_HEADLESS:-true} E2E_FORM_VIEWER_URL=${E2E_FORM_VIEWER_URL:-http://localhost:5173} E2E_BACKEND_URL=${E2E_BACKEND_URL:-http://localhost:4000} pnpm test:e2e --tags '@mass-responses'",
    "test:e2e:max-responses": "E2E_EMAIL=${E2E_EMAIL:-cloude2etest@mailinator.com} E2E_PASSWORD=${E2E_PASSWORD:-cloude2etest@mailinator.com} E2E_FORM_APP_URL=${E2E_FORM_APP_URL:-http://localhost:3000} E2E_HEADLESS=${E2E_HEADLESS:-true} E2E_FORM_VIEWER_URL=${E2E_FORM_VIEWER_URL:-http://localhost:5173} E2E_BACKEND_URL=${E2E_BACKEND_URL:-http://localhost:4000} pnpm test:e2e --tags '@max-responses'"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.2.0",
    "@istanbuljs/nyc-config-typescript": "1.0.2",
    "@playwright/test": "^1.60.0",
    "@prisma/adapter-pg": "6.19.2",
    "@types/country-list": "2.1.4",
    "@types/express": "^4.17.25",
    "@types/form-data": "2.5.2",
    "@types/jest": "^29.5.14",
    "@types/mailparser": "3.4.6",
    "@types/node": "^20.19.42",
    "@types/smtp-server": "3.5.13",
    "@types/supertest": "6.0.3",
    "@types/ua-parser-js": "0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "axios": "^1.17.0",
    "c8": "10.1.3",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "eslint": "^8.57.1",
    "exceljs": "4.4.0",
    "form-data": "4.0.6",
    "jest": "^29.7.0",
    "lefthook": "2.1.10",
    "lint-staged": "17.2.0",
    "mailparser": "^3.9.9",
    "mongodb-memory-server": "10.3.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "smtp-server": "3.19.2",
    "source-map-support": "0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.2",
    "typescript": "^5.9.3",
    "ws": "^8.21.0",
    "yjs": "13.6.31"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "lint-staged": {
    "apps/backend/src/**/*.ts": "eslint --fix",
    "apps/form-app/src/**/*.{ts,tsx}": "eslint --fix",
    "apps/form-viewer/src/**/*.{ts,tsx}": "eslint --fix",
    "apps/admin-app/src/**/*.{ts,tsx}": "eslint --fix",
    "packages/**/*.{ts,tsx}": "eslint --fix"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0",
      "react": "^18.3.0",
      "react-dom": "^18.3.0",
      "@smithy/types": "4.3.2",
      "fast-xml-parser": ">=5.3.5",
      "tmp": ">=0.2.6",
      "path-to-regexp": "0.1.13",
      "follow-redirects": ">=1.16.0",
      "tar-fs": ">=2.1.4",
      "react-router": "^7.9.4",
      "handlebars": "^4.7.9",
      "yauzl": ">=3.2.1",
      "@protobufjs/utf8": "1.1.1",
      "mailparser": ">=3.9.3",
      "picomatch": ">=2.3.2",
      "brace-expansion": "^1.1.13",
      "qs": ">=6.15.2",
      "flatted": ">=3.4.2",
      "defu": ">=6.1.5",
      "jws": ">=3.2.3",
      "@sentry/node-core": ">=10.27.0",
      "js-yaml": ">=4.1.1",
      "rollup": ">=4.59.0",
      "playwright": ">=1.55.1",
      "zod": ">=4.4.3",
      "@types/express-serve-static-core": "4.19.8",
      "better-auth": ">=1.6.23",
      "effect": ">=3.20.0",
      "lodash": ">=4.17.23",
      "nodemailer": ">=8.0.5",
      "drizzle-orm": ">=0.45.2",
      "tar": ">=7.5.11"
    }
  },
  "dependencies": {
    "@maxmind/geoip2-node": "6.1.0",
    "@radix-ui/react-label": "2.1.13",
    "@radix-ui/react-select": "2.3.5",
    "@radix-ui/react-slot": "1.3.1",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "country-list": "^2.4.1",
    "graphql-request": "7.4.0",
    "lucide-react": "0.534.0",
    "nanoid": "5.1.5",
    "tailwind-merge": "3.3.1",
    "ua-parser-js": "^1.0.41"
  }
}